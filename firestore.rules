rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: saves
    // Document ID: {userId}
    // Fields:
    //   - gameState: map (contains the user's single-player save data)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - name: string
    //   - photoURL: string
    //   - progress: map
    //
    // Collection: friendRequests
    // Document ID: auto-generated
    // Fields:
    //   - senderId: string
    //   - receiverId: string
    //   - status: string ('pending', 'accepted', 'declined')
    //   - createdAt: timestamp
    //
    // Collection: rooms
    // Document ID: auto-generated
    // Fields:
    //   - roomCode: string (required) - unique code for joining
    //   - status: string (required) - 'waiting', 'playing', 'finished'
    //   - player1: map (required) - { id, uid, name, team, activeIdx, hp }
    //   - player2: map (optional) - { id, uid, name, team, activeIdx, hp }
    //   - currentTurnId: string (required) - UID of the player whose turn it is
    //   - logs: list (required) - battle log messages
    //   - winnerId: string (optional) - UID of the winner
    //   - updatedAt: timestamp (required)
    //   - isPrivate: bool (optional)
    //   - targetPlayerId: string (optional)
    //
    // Collection: matchmaking
    // Document ID: userId
    // Fields:
    //   - userId: string (required)
    //   - name: string (required)
    //   - team: list (required)
    //   - hp: list (required)
    //   - createdAt: timestamp (required)
    //   - matchedRoomId: string (optional)
    //
    // Collection: tournaments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - hostId: string (required)
    //   - players: list (required) - array of { id, name, team }
    //   - status: string (required) - 'waiting', 'semifinals', 'final', 'finished'
    //   - matches: map (required) - { semi1, semi2, final }
    //   - winnerId: string (optional) - UID of the winner
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() < 100;
    }

    function isValidFriendRequest(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'status', 'createdAt'])
        && data.senderId is string
        && data.receiverId is string
        && data.status in ['pending', 'accepted', 'declined']
        && data.createdAt is timestamp;
    }

    function isValidPlayer(player) {
      return player is map 
        && player.keys().hasAll(['id', 'uid', 'name', 'team', 'activeIdx', 'hp'])
        && player.id is string
        && player.uid is string
        && player.name is string
        && player.team is list
        && player.team.size() <= 6
        && player.activeIdx is number
        && player.hp is list;
    }

    function isValidRoom(data) {
      let baseFields = ['status', 'player1', 'currentTurnId', 'logs', 'updatedAt'];
      return data.keys().hasAll(baseFields)
        && data.status in ['waiting', 'playing', 'finished']
        && isValidPlayer(data.player1)
        && (!('player2' in data) || data.player2 == null || isValidPlayer(data.player2))
        && (!('currentTurnId' in data) || data.currentTurnId == null || data.currentTurnId is string)
        && data.logs is list
        && (!('winnerId' in data) || data.winnerId == null || data.winnerId is string)
        && data.updatedAt is number;
    }

    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'hostId', 'isPublic', 'mode', 'players', 'status', 'matches', 'winnerId', 'createdAt'])
        && data.name is string
        && data.hostId is string
        && data.isPublic is bool
        && data.mode in ['libre', 'competitivo']
        && data.players is list
        && data.status in ['waiting', 'semifinals', 'final', 'finished']
        && data.matches is map
        && (data.winnerId == null || data.winnerId is string)
        && data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /saves/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);

      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.receiverId && isValidFriendRequest(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    match /matchmaking/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(userId);
      // Allow others to delete when they match
      allow delete: if isAuthenticated(); 
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() 
        && isValidRoom(request.resource.data)
        && request.resource.data.status == 'waiting'
        && request.resource.data.player1.uid == request.auth.uid;

      allow update: if isAuthenticated() 
        && isValidRoom(request.resource.data)
        && (
          // 1. Player 2 joins the room
          (resource.data.status == 'waiting' 
           && request.resource.data.status == 'waiting'
           && request.resource.data.player2 != null
           && request.resource.data.player2.uid == request.auth.uid)
          ||
          // 2. Player 1 or Player 2 updates their team/mode while waiting
          (resource.data.status == 'waiting'
           && request.resource.data.status == 'waiting'
           && (request.auth.uid == resource.data.player1.uid || (resource.data.player2 != null && request.auth.uid == resource.data.player2.uid)))
          ||
          // 3. Player 1 starts the game or Quick Match
          (resource.data.status == 'waiting'
           && request.resource.data.status == 'playing'
           && resource.data.player1.uid == request.auth.uid
           && request.resource.data.player2 != null)
          ||
          // 4. Playing the game / Finishing
          ((resource.data.status == 'playing' || resource.data.status == 'finished')
           && (request.auth.uid == resource.data.player1.uid || (resource.data.player2 != null && request.auth.uid == resource.data.player2.uid)))
          ||
          // 5. Resetting a room (Host only)
          (resource.data.status == 'finished'
           && request.resource.data.status == 'waiting'
           && resource.data.player1.uid == request.auth.uid)
        );

      allow delete: if isAuthenticated() 
        && resource.data.player1.uid == request.auth.uid;
    }
  }
}
